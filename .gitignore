# Editor, merge, and temporary files
*~
*.bak
*.tmp
*.temp
*.orig
*.rej
.DS_Store
Thumbs.db
desktop.ini

# Tool caches
__pycache__/
*.py[cod]
.pytest_cache/

# MATLAB local autosaves from debug/viewer scripts
*.asv

# S32DS/Eclipse workspace metadata belongs outside the project.
# Project metadata is intentionally tracked: .project, .cproject, .settings/.
/.metadata/
